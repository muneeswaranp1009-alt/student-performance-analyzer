def analyze_marks(marks_input):
    try:
        string_list = marks_input.split(',')
        marks = []
        
        for m in string_list:
               cleaned_mark = m.strip()
               
               if not cleaned_mark.isdigit():
                   raise ValueError(f"Type Error: '{cleaned_mark}' is not a valid number.")
               
               numeric_mark = int(cleaned_mark)
               
               if numeric_mark < 0 or numeric_mark > 100:
                   raise ValueError(f"Limit Error: '{numeric_mark}' is invalid. Marks must be strictly between 0 and 100.")
               marks.append(numeric_mark)
            
        pass_count = 0
        fail_count = 0
        total = 0
        
        highest = marks[0]
        lowest = marks[0]
    
        for mark in marks:
            if mark >= 35:
                pass_count += 1
            else:
                fail_count += 1
            
            if highest < mark:
                highest = mark
            
            if lowest > mark:
                lowest = mark
            
            total += mark
        
        average = total / len(marks)
    
        print("\n---  Student Results Report ---")
        print(f"Total Students Analyzed : {len(marks)}")
        print(f"Pass Students Count   : {pass_count}")
        print(f"Fail Students Count   : {fail_count}")
        print(f"Highest Mark          : {highest}")
        print(f"Lowest Mark           : {lowest}")
        print(f"Average Mark          : {average:.2f}")
    
    except ValueError:
        print("\n Float Error:Please enter the valid number, not letters and above 100 (eg: 85, 80, 75, 28, 19)")
    except Exception as e:
        print(f"\nInput Handling error:{e}")



print(">>>>>>>>>>Welcome to the Student Analyzer<<<<<<<<<<<")
user_input = input("Enter multiple student marks (comma separated, e.g., 45, 80, 22, 99, 35): ")

if __name__ == "__main__":
    analyze_marks(user_input)